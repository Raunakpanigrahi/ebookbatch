{
  "name": "ebook-batch-converter",
  "version": "1.0.0",
  "description": "A desktop application to batch convert PDF files to EPUB format",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "Raunak Panigrahi",
  "license": "MIT",
  "build": {
    "appId": "com.ebookbatch.app",
    "productName": "EbookBatch",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "epubjs": "^0.3.93",
    "jszip": "^3.10.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
